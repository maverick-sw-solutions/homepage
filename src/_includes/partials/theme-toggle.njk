<div class="theme-toggle">
  <button class="theme-toggle__btn" data-theme-btn="light" aria-label="Tema claro"><i class="fa-solid fa-sun"></i></button>
  <button class="theme-toggle__btn" data-theme-btn="system" aria-label="Tema do sistema"><i class="fa-solid fa-circle-half-stroke"></i></button>
  <button class="theme-toggle__btn" data-theme-btn="dark" aria-label="Tema escuro"><i class="fa-solid fa-moon"></i></button>
</div>
